# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
# Set to your frontend URL in production (e.g., http://slackwater.app)
# Use * for development to allow all origins
CORS_ORIGIN=*

# API Configuration
# NOAA CO-OPS API base URL
NOAA_BASE_URL=https://api.tidesandcurrents.noaa.gov/api/prod/datagetter

# NWS API base URL
NWS_BASE_URL=https://api.weather.gov

# USNO API base URL
USNO_BASE_URL=https://aa.usno.navy.mil/api

# Request timeout (milliseconds)
REQUEST_TIMEOUT=10000

# Application identifier for NOAA API
NOAA_APP_ID=slackwater_backend

# Database Configuration
# SQLite database file paths (relative to project root)
DB_OPERATIONAL=./data/operational.db
DB_ANALYTICS=./data/analytics.db

# Cache Settings
# TTL in seconds (360 = 6 minutes, matches NOAA update frequency)
CACHE_TTL_SECONDS=360

# Dashboard Configuration
DASHBOARD_PORT=8080
DASHBOARD_USERNAME=admin
# Generate password hash with: node -e "require('bcrypt').hash('yourpassword', 10).then(console.log)"
DASHBOARD_PASSWORD_HASH=your_bcrypt_hash_here

# Session secret for dashboard (use a long random string in production!)
SESSION_SECRET=change-this-to-a-secure-random-string

# Analytics Settings
# Set to false to disable request tracking
ANALYTICS_ENABLED=true

# Data Retention
# Number of days to keep fetch logs and analytics data
RETENTION_DAYS=30
